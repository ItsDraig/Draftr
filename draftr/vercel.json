{
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/api"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/_svc/backend/$1" },
    { "source": "/health",   "destination": "/_svc/backend/health" }
  ]
}