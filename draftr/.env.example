# ── Backend (.env in /backend) ──────────────────────────────
PORT=3001
# URL of the frontend (for CORS). Change this when deploying.
FRONTEND_URL=http://localhost:5173

# ── Frontend (.env in /frontend) ────────────────────────────
# If left blank, the Vite proxy handles /api in dev.
# Set this to your backend URL when deploying (e.g. https://api.draftr.gg)
VITE_API_URL=
